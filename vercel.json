{
  "version": 2,
  "name": "gaming-chat-proxy-api",
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/server.js"
    },
    {
      "src": "/uploads/(.*)",
      "dest": "/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "/server.js"
    }
  ],
  "env": {
    "GOOGLE_API_KEY": "@google-api-key"
  },
  "functions": {
    "server.js": {
      "maxDuration": 30
    }
  }
}
